# Uncomment this line to define a global platform for your project
platform :ios, '15.1'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

def patch_jitsi_plugin_registration
  plugin_swift = File.expand_path('.symlinks/plugins/jitsi_meet_flutter_sdk/ios/Classes/JitsiMeetPlugin.swift', __dir__)
  return unless File.exist?(plugin_swift)

  content = File.read(plugin_swift)

  replacement = <<~SWIFT
        let flutterViewController: UIViewController = registrar.viewController
            ?? UIApplication.shared.connectedScenes
                .compactMap({ $0 as? UIWindowScene })
                .flatMap({ $0.windows })
                .first(where: { $0.isKeyWindow })?.rootViewController
            ?? UIViewController()
  SWIFT

  already_patched = /let flutterViewController:\s*UIViewController\s*=\s*registrar\.viewController/m
  return if content.match?(already_patched)

  original_block = /guard\s+let\s+flutterViewController:\s*UIViewController\s*=\s*UIApplication\.shared\.connectedScenes\s*\n\s*\.compactMap\(\{\s*\$0\s+as\?\s+UIWindowScene\s*\}\)\s*\n\s*\.flatMap\(\{\s*\$0\.windows\s*\}\)\s*\n\s*\.first\(where:\s*\{\s*\$0\.isKeyWindow\s*\}\)\?\.rootViewController\s*else\s*\{\s*return\s*\}/m

  unless content.match?(original_block)
    puts 'Jitsi registration block not found; skipping patch.'
    return
  end

  patched = content.sub(original_block, replacement.rstrip)
  return if patched == content

  File.write(plugin_swift, patched)
  puts 'Patched jitsi_meet_flutter_sdk iOS registration fallback for event channel setup.'
end

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  patch_jitsi_plugin_registration

  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      if config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'].to_f < 15.1
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.1'
      end
    end
  end
end
